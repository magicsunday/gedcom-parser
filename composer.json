{
    "name": "magicsunday/gedcom-parser",
    "description": "A GEDCOM 5.5.1 file parser",
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/magicsunday/gedcom-parser",
    "keywords": [
        "gedcom",
        "parser"
    ],
    "authors": [
        {
            "name": "Rico Sonntag",
            "email": "mail@ricosonntag.de",
            "homepage": "https://ricosonntag.de",
            "role": "Developer"
        }
    ],
    "config": {
        "bin-dir": ".build/bin",
        "vendor-dir": ".build/vendor",
        "discard-changes": true,
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform-check": false
    },
    "require": {
        "php": "^8.3",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.85",
        "overtrue/phplint": "^9.0",
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "MagicSunday\\Gedcom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MagicSunday\\Gedcom\\Test\\": "test/"
        }
    },
    "scripts": {
        "ci:test:php:lint": [
            "phplint"
        ],
        "ci:test:php:phpstan": [
            "phpstan analyze"
        ],
        "ci:test:php:phpstan:baseline": [
            "phpstan analyze --generate-baseline phpstan-baseline.neon --allow-empty-baseline"
        ],
        "ci:test:php:rector": [
            "rector process --config rector.php --dry-run"
        ],
        "ci:test:php:unit": [
            "phpunit"
        ],
        "ci:cgl": [
            "php-cs-fixer fix --diff --verbose"
        ],
        "ci:test": [
            "@ci:test:php:lint",
            "@ci:test:php:phpstan",
            "@ci:test:php:rector",
            "@ci:test:php:unit"
        ]
    }
}
