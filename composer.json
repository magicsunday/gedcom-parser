{
    "name": "magicsunday/gedcom-parser",
    "description": "A GEDCOM 5.5.1 file parser",
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/magicsunday/gedcom-parser",
    "keywords": [
        "gedcom",
        "parser"
    ],
    "authors": [
        {
            "name": "Rico Sonntag",
            "email": "mail@ricosonntag.de",
            "homepage": "https://ricosonntag.de",
            "role": "Developer"
        }
    ],
    "config": {
        "bin-dir": ".build/bin",
        "vendor-dir": ".build/vendor",
        "discard-changes": true,
        "sort-packages": true,
        "optimize-autoloader": true,
        "platform-check": false
    },
    "require": {
        "php": "^8.3",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "magicsunday/jsonmapper": "^3.1",
        "phpdocumentor/reflection-docblock": "^5.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "symfony/property-access": "^7.4 || ^8.0",
        "symfony/property-info": "^7.4 || ^8.0",
        "symfony/yaml": "^7.4 || ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.85",
        "overtrue/phplint": "^9.0",
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "MagicSunday\\Gedcom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MagicSunday\\Gedcom\\Test\\": "test/"
        }
    },
    "scripts": {
        "ci:cgl": [
            "php-cs-fixer fix --config .php-cs-fixer.dist.php --diff --verbose"
        ],
        "ci:rector": [
            "rector process --config rector.php"
        ],
        "ci:test:php:cgl": [
            "@ci:cgl --dry-run"
        ],
        "ci:test:php:cpd": [
            "npx --yes jscpd@^5.0.11 --config .jscpd.json --skip-comments --no-tips"
        ],
        "ci:test:php:lint": [
            "phplint --configuration .phplint.yml"
        ],
        "ci:test:php:phpstan": [
            "phpstan analyze --configuration phpstan.neon --memory-limit=-1"
        ],
        "ci:test:php:rector": [
            "@ci:rector --dry-run"
        ],
        "ci:test:php:unit": [
            "phpunit --configuration phpunit.xml"
        ],
        "ci:test:php:unit:coverage": [
            "XDEBUG_MODE=coverage phpunit --configuration phpunit.xml --coverage-html .build/coverage/"
        ],
        "ci:test": [
            "@ci:test:php:lint",
            "@ci:test:php:unit",
            "@ci:test:php:phpstan",
            "@ci:test:php:rector",
            "@ci:test:php:cgl",
            "@ci:test:php:cpd"
        ],
        "post-update-cmd": [
            "npm install --prefix .build jscpd@^5.0.11"
        ]
    }
}
