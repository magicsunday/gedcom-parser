includes:
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-strict-rules/rules.neon
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-deprecation-rules/rules.neon
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-phpunit/extension.neon
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-phpunit/rules.neon
    - %currentWorkingDirectory%/.build/vendor/phpat/phpat/extension.neon

parameters:
    # The typed-model refactor (GH-20) removed the untyped DataObject bag and its mixed-return
    # errors, so the analysis now runs clean at the strictest level with no baseline.
    level: max

    # Report the failing rule method name (not just the class pair) when an architecture rule breaks.
    phpat:
        show_rule_names: true

    tmpDir: %currentWorkingDirectory%/.build/cache/.phpstan.cache

    paths:
        - %currentWorkingDirectory%/src/
        - %currentWorkingDirectory%/tests/
        - %currentWorkingDirectory%/tools/

    excludePaths:
        - %currentWorkingDirectory%/.build/

    fileExtensions:
        - php

    # Ignored validations
    treatPhpDocTypesAsCertain: false

services:
    # Architecture rules enforced by phpat during the analysis (see tests/Architecture).
    -
        class: MagicSunday\Gedcom\Test\Architecture\ArchitectureTest
        tags:
            - phpat.test
