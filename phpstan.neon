includes:
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-strict-rules/rules.neon
    - %currentWorkingDirectory%/.build/vendor/phpstan/phpstan-deprecation-rules/rules.neon
#    - %currentWorkingDirectory%/phpstan-baseline.neon

parameters:
    # Level 9 for now; the untyped DataObject bag still produces mixed-return errors
    # that only the typed-model refactor (GH-20) can resolve. Raise to `max` with GH-20.
    level: 9

    paths:
        - %currentWorkingDirectory%/src/

    excludePaths:
        - %currentWorkingDirectory%/.build/

    fileExtensions:
        - php

    # Ignored validations
    treatPhpDocTypesAsCertain: false
